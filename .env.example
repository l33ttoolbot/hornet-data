# Hornet-Data Pipeline Environment Variables
# Copy this file to .env and fill in your API keys

# Flickr API
FLICKR_API_KEY=your_flickr_api_key_here
FLICKR_API_SECRET=your_flickr_api_secret_here

# iNaturalist (optional, for higher rate limits)
INATURALIST_API_KEY=your_inaturalist_api_key_here

# GBIF (optional, for higher rate limits)
GBIF_API_KEY=your_gbif_api_key_here

# Waarnemingen.nl / Observation.org
WAARNEMINGEN_API_KEY=your_waarnemingen_api_key_here

# Pipeline Settings
RATE_LIMIT_DEFAULT=1.0
MAX_RETRIES=3
REQUEST_TIMEOUT=30

# Logging Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO