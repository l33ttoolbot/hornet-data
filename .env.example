# Hornet-Data Pipeline Environment Variables
# Copy this file to .env and fill in your API keys

# ═══════════════════════════════════════════════════════════════
# API Keys Status
# ═══════════════════════════════════════════════════════════════
# Kaggle:        ✅ CONFIGURED (stored in ~/.kaggle/kaggle.json)
# iNaturalist:   ✅ NO KEY NEEDED (open API)
# Flickr:        ❌ NOT AVAILABLE (requires Pro account)
# ═════════════════════════════════════════════════════════════════=


# Flickr API (NOT AVAILABLE - no key)
FLICKR_API_KEY=
FLICKR_API_SECRET=

# iNaturalist (WORKS WITHOUT KEY - rate limit 100req/min)
# Optional key for higher rate limits
INATURALIST_API_KEY=

# GBIF (optional, for higher rate limits)
GBIF_API_KEY=

# Waarnemingen.nl / Observation.org
WAARNEMINGEN_API_KEY=

# Pipeline Settings
RATE_LIMIT_DEFAULT=1.0
MAX_RETRIES=3
REQUEST_TIMEOUT=30

# Logging Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO